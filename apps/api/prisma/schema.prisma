generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Owner {
  id        String    @id @default(uuid())
  name      String
  document  String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vehicles  Vehicle[]

  @@map("owners")
}

model Vehicle {
  id        String   @id @default(uuid())
  plate     String   @unique
  model     String?
  color     String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     Owner    @relation(fields: [ownerId], references: [id])
  records   ParkingRecord[]

  @@index([ownerId])
  @@map("vehicles")
}

model ParkingRecord {
  id        String    @id @default(uuid())
  vehicleId String
  entryAt   DateTime  @default(now())
  exitAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("parking_records")
}